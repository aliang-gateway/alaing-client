{
    "core": {
        "engine": {
            "mtu": 0,
            "fwmark": 0,
            "restapi": "",
            "device": "utun0",
            "loglevel": "info",
            "interface": "en0",
            "tcp-moderate-receive-buffer": false,
            "tcp-send-buffer-size": "",
            "tcp-receive-buffer-size": "",
            "multicast-groups": "",
            "tun-pre-up": "",
            "tun-post-up": "",
            "udp-timeout": "60s"
        },
        "aliangServer": {
            "type": "aliang",
            "core_server": "ai-gateway.nursor.org:443"
        }
    },
    "customer": {
        "proxy": {
            "type": "socks",
            "server": "127.0.0.1:1080",
            "username": "",
            "password": ""
        },
        "ai_rules":{
          "openai":{
            "enable": true,
            "exclude": [
              "api.openai.com",
              "cdn.openai.com"
            ]
          },
          "claude":{
            "enable": true,
            "exclude": [
              "claude.ai",
              "claude.com"
            ]
          },
          "gemini":{
            "enable": true,
            "exclude": [
              "gemini.google.com"
            ]
          }
        },
        "proxy_rules": {
          "enabled": true,
          "rules":[
            "domains,cursor.com",
            "domains,*.cursor.com",
            "domains,*.nursor.org",
            "ip,192.168.0.0/16"
        ]
        }
    }
}