{
  "version": 1,
  "ingress": {
    "mode": "tun"
  },
  "egress": {
    "direct": {
      "enabled": true
    },
    "toSocks": {
      "enabled": true,
      "upstream": {
        "type": "socks"
      }
    },
    "toAliang": {
      "enabled": true
    }
  },
  "routing": {
    "rules": [
      {
        "id": "rule-001-google",
        "type": "domain",
        "condition": "*.google.com",
        "target": "toSocks",
        "enabled": true
      },
      {
        "id": "rule-002-github",
        "type": "domain",
        "condition": "*.github.com",
        "target": "toSocks",
        "enabled": true
      },
      {
        "id": "rule-003-facebook",
        "type": "domain",
        "condition": "*.facebook.com",
        "target": "toSocks",
        "enabled": true
      },
      {
        "id": "rule-004-us-geoip",
        "type": "geoip",
        "condition": "US",
        "target": "toSocks",
        "enabled": true
      },
      {
        "id": "rule-005-eu-geoip",
        "type": "geoip",
        "condition": "GB",
        "target": "toSocks",
        "enabled": false
      },
      {
        "id": "rule-006-private-ip",
        "type": "ip",
        "condition": "192.168.0.0/16",
        "target": "direct",
        "enabled": true
      },
      {
        "id": "rule-007-internal-domain",
        "type": "domain",
        "condition": "*.internal.company.com",
        "target": "toAliang",
        "enabled": true
      }
    ]
  },
  "migration": {
    "note": "Legacy route aliases were removed. Please use canonical targets direct, toSocks, and toAliang only."
  }
}
