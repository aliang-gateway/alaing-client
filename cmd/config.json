        },
        "aliangServer": {
            "type": "aliang",
            "core_server": "15.nat0.cn:16749"
        },
        "api_server": "https://api.aliang.one"
    },
    "customer": {
        "proxy": {
            "enable": false,
            "type": "socks5",
            "server": "127.0.0.1:1080",
            "username": "",
            "password": ""
        },
        "ai_rules":{
            "Anthropic": {
              "enble": true,
              "editable": true,
              "include": [
                "api.aliang.one",
                "api.anthropic.com"
              ]
            },
            "openai": {
              "enble": true,
              "editable": true,
              "include": [
                "api.openai.com",
                "cdn.openai.com",
                "api.aliang.one"
              ]
            },
            "vscode": {
              "enble": true,
              "editable": false,
              "include": [
                "api.githubcopilot.com",
                "*.individual.githubcopilot.com"
              ]
            },
            "cursor": {
              "enble": true,
              "editable": false,
              "include": [
                "*.cursor.sh"
              ]
            }
        },
        "proxy_rules": [
            "domains,google.com",
            "domains,youtube.com",
            "domains,facebook.com",
            "domains,twitter.com",
            "domains,instagram.com",
            "domains,netflix.com",
