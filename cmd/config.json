{
  
    "core": {
        "engine": {
            "mtu": 0,
            "fwmark": 0,
            "restapi": "",
            "device": "utun0",
            "loglevel": "info",
            "interface": "en0",
            "tcp-moderate-receive-buffer": false,
            "tcp-send-buffer-size": "",
            "tcp-receive-buffer-size": "",
            "multicast-groups": "",
            "tun-pre-up": "",
            "tun-post-up": "",
            "udp-timeout": "60s"
        },
        "aliangServer": {
            "type": "aliang",
            "core_server": "ai-gateway.aliang.one:443"
        },
        "api_server": "https://api.aliang.one"
    },
    "customer": {
        "proxy": {
            "type": "socks5",
            "server": "127.0.0.1:1080",
            "username": "",
            "password": ""
        },
        "ai_rules":{
           "vscode": {
              "enble": true,
              "include": [
                "*.githubcopilot.com"
              ]
            },
            "Anthropic": {
              "enble": true,
              "include": [
                "api.aliang.one",
                "api.anthropic.com"
              ]
            },
            "openai": {
              "enble": true,
              "include": [
                "api.openai.com",
                "cdn.openai.com",
                "api.aliang.one"
              ]
            }
        },
        "proxy_rules": [
            "domains,cursor.com",
            "domains,*.cursor.com",
            "domains,*.aliang.one"
        ]
    }
}