{
  
    "core": {
        "engine": {
            "mtu": 0,
            "fwmark": 0,
            "restapi": "",
            "device": "utun0",
            "loglevel": "info",
            "interface": "en0",
            "tcp-moderate-receive-buffer": false,
            "tcp-send-buffer-size": "",
            "tcp-receive-buffer-size": "",
            "multicast-groups": "",
            "tun-pre-up": "",
            "tun-post-up": "",
